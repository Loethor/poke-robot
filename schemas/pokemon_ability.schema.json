{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "required": [
        "generation",
        "name",
        "pokemon"
    ],
    "properties": {
        "generation": {
            "type": "object",
            "maximum": 1
        },
        "name": {
            "type": "string"
        },
        "pokemon": {
            "type": "array"
        }
    }
}